APP_ENV=local

SCRAPER_START_URL=https://www.bbva.com.co/
SCRAPER_ALLOWED_DOMAIN=www.bbva.com.co
SCRAPER_MAX_PAGES=25
SCRAPER_TIMEOUT_SECONDS=15

RAW_DATA_PATH=/app/data/raw/pages.jsonl
CLEAN_DATA_PATH=/app/data/clean/documents.jsonl
VECTOR_DB_PATH=/app/data/chroma
SQLITE_DB_PATH=/app/database/conversations.db

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

LLM_PROVIDER=hf_local
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
MAX_NEW_TOKENS=180
TEMPERATURE=0.1

CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
RERANK_TOP_K=3
MEMORY_N_MESSAGES=4
ANONYMIZED_TELEMETRY=false

ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

API_BASE_URL=http://api:8000